# ─── Required ────────────────────────────────────────────────────────────────

# SQLite database path (relative to project root or absolute)
DATABASE_URL="file:./tunnel-manager.db"

# 32-character (256-bit) secret used to encrypt Cloudflare credentials at rest.
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY="change-me-to-a-32-byte-hex-secret-value"

# 32+ character secret for iron-session cookie signing.
# Generate with: openssl rand -base64 32
SESSION_SECRET="change-me-to-a-long-random-session-secret"

# ─── Optional ────────────────────────────────────────────────────────────────

# Port for the Next.js server (default: 3000)
PORT=3000

# Set to "production" in production environments
NODE_ENV="development"

# Background sync interval in milliseconds (default: 60000 = 1 minute)
SYNC_INTERVAL_MS=60000

# Maximum Cloudflare API retry attempts (default: 3)
CF_MAX_RETRIES=3

# Base delay for exponential backoff in ms (default: 500)
CF_RETRY_BASE_DELAY_MS=500
